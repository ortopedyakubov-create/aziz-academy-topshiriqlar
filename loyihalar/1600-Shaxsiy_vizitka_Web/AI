<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Abdugani AI.pro</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0a0a;
      color: #fff;
      height: 100vh;
      overflow: hidden;
      transition: background 0.6s;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      text-align: center;
      padding: 20px;
      border-bottom: 1px solid #333;
    }

    h1 {
      font-size: 28px;
      background: linear-gradient(90deg, #00ff88, #00ccff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .status {
      color: #ff4444;
      font-weight: bold;
      margin: 10px 0;
    }

    .chat {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .message {
      max-width: 80%;
      padding: 14px 18px;
      border-radius: 18px;
      line-height: 1.5;
    }

    .bot {
      align-self: flex-start;
      background: #1f1f1f;
      border-bottom-left-radius: 4px;
    }

    .user {
      align-self: flex-end;
      background: #00cc88;
      color: black;
      border-bottom-right-radius: 4px;
    }

    .input-area {
      padding: 20px;
      background: #111;
      border-top: 1px solid #333;
    }

    input {
      width: 100%;
      padding: 16px 20px;
      border: none;
      border-radius: 50px;
      background: #222;
      color: white;
      font-size: 16px;
    }

    .modes {
      text-align: center;
      padding: 10px;
      font-size: 14px;
    }

    .mode-btn {
      background: none;
      border: 1px solid #444;
      color: #aaa;
      padding: 6px 12px;
      margin: 4px;
      border-radius: 20px;
      cursor: pointer;
      transition: all 0.3s;
    }

    .mode-btn.active {
      background: #00ff88;
      color: black;
      border-color: #00ff88;
    }

    .header-buttons {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin: 10px 0;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Abdugani AI.pro</h1>
      <p class="status">● Tizim faol</p>
      
      <div class="modes">
        Fon: 
        <button class="mode-btn active" onclick="changeBg(0)">Toza 🔇</button>
        <button class="mode-btn" onclick="changeBg(1)">Qora Tuynuk 🌌</button>
        <button class="mode-btn" onclick="changeBg(2)">Olov 🔥</button>
        <button class="mode-btn" onclick="changeBg(3)">Yomg'ir 🌧️</button>
        <button class="mode-btn" onclick="changeBg(4)">Yulduzlar ✨</button>
      </div>
    </header>

    <div class="chat" id="chat">
      <div class="message bot">
        Salom! Men Abdugani AI.pro. Sizga qanday yordam bera olaman?
      </div>
    </div>

    <div class="input-area">
      <input type="text" id="userInput" placeholder="Savolingizni yozing..." onkeypress="if(event.key === 'Enter') sendMessage()">
    </div>
  </div>

  <script>
    const chat = document.getElementById('chat');
    const input = document.getElementById('userInput');

    const backgrounds = [
      '#0a0a0a',                    // Toza
      'linear-gradient(45deg, #000428, #004e92)', // Qora tuynuk
      'linear-gradient(45deg, #8B0000, #FF4500)', // Olov
      'linear-gradient(45deg, #0f2027, #203a43, #2c5364)', // Yomg'ir
      'radial-gradient(circle, #1a0033, #000000)' // Yulduzlar
    ];

    function changeBg(n) {
      document.body.style.background = backgrounds[n];
      document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.mode-btn')[n].classList.add('active');
    }

    function addMessage(text, isUser) {
      const msg = document.createElement('div');
      msg.className = `message ${isUser ? 'user' : 'bot'}`;
      msg.textContent = text;
      chat.appendChild(msg);
      chat.scrollTop = chat.scrollHeight;
    }

    async function sendMessage() {
      const text = input.value.trim();
      if (!text) return;

      addMessage(text, true);
      input.value = '';

      // Oddiy sun'iy intellekt javoblari (o'zbekcha)
      const responses = {
        "salom": "Salom! Qalaysiz?",
        "qalaysiz": "Rahmat, yaxshi! Siz-chi?",
        "kim": "Men Abdugani AI.pro — sizning shaxsiy yordamchingiz.",
        "vaqt": `Hozirgi vaqt: ${new Date().toLocaleTimeString('uz-UZ')}`,
        "bugun": "Bugun juda ajoyib kun bo'lishiga ishonaman! 😊",
        "yordam": "Men sizga savollaringizga javob berishim, maslahat berishim yoki shunchaki suhbatlashishim mumkin.",
      };

      let reply = "Tushundim. Yana aniqroq yozib bersangiz yaxshi bo'lardi.";

      const lowerText = text.toLowerCase();
      
      for (let key in responses) {
        if (lowerText.includes(key)) {
          reply = responses[key];
          break;
        }
      }

      // Biroz kutish effekti
      setTimeout(() => {
        addMessage(reply, false);
      }, 600);
    }

    // Sahifa yuklanganda salomlashish
    window.onload = () => {
      setTimeout(() => {
        addMessage("Tizim muvaffaqiyatli ishga tushirildi. Savolingizni yozing!", false);
      }, 800);
    };
  </script>
</body>
</html>